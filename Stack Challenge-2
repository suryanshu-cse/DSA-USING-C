#include <stdio.h>
#include <string.h>
#include <math.h>
#include <stdlib.h>
int max,stack[100],top=-1,value;
void push(){
    if(top==max-1){
        printf("Overflow\n");
    }
    else{
        stack[++top]=value;
    }
}
int pop(){
    if(top==-1){
        printf("Underflow\n");
        return -1;
        
    }
    else{
        return stack[top--];

    }
}
void display(){
    if(top==-1){
        printf("Stack is Empty\n");
    }
    else{
        for(int i=top;i>=0;i--){
        printf("%d ",stack[i]);
    }
}
}

int main() {
    scanf("%d",&max);
    int res;
int n;
    scanf("%d",&n);
    for(int i=0;i<n;i++){
        scanf("%d",&value);
        push();
         }
    for(int i=0;i<2;i++){
       res=pop();
        if(res!=-1){
            printf("Popped: %d\n",res);
        }
    }
    for(int i=0;i<4;i++){
         scanf("%d",&value);
        
         push();
    }
    res=pop();
        if(res!=-1){
printf("Popped: %d\n",res);
        }
     for(int i=0;i<2;i++){
         scanf("%d",&value);
         push();
    }
    for(int i=0;i<3;i++){
       res=pop();
        if(res!=-1){
            printf("Popped: %d\n",res);
        }
    }
    
display();
        
    
    
    


    return 0;
}
