#include<stdio.h>
#include<stdlib.h>
#include<ctype.h>
#include<string.h>

int precedence(char op){
    switch(op){
        case '+':
        case '-':
            return 1;
        case '*':
        case '/':
            return 2;
        case '^':
            return 3;
        default:
            return 0;
    }
}

char* convertinfixtopostfix(char* infixExp){
    int len = strlen(infixExp), top = -1, x = 0;
    char *postfix = (char*)malloc(len + 1);
    char operator[100];

    for(int i = 0; i < len; i++){
        char ch = infixExp[i];

        if(isalnum(ch)){
            postfix[x++] = ch;
        }
        else if(ch == '('){
            operator[++top] = ch;
        }
        else if(ch == ')'){
            while(top != -1 && operator[top] != '('){
                postfix[x++] = operator[top--];
            }
            top--;
        }
        else{
            while(top != -1 &&
                  operator[top] != '(' &&
                  (precedence(ch) < precedence(operator[top]) ||
                  (precedence(ch) == precedence(operator[top]) && ch != '^')))
            {
                postfix[x++] = operator[top--];
            }
            operator[++top] = ch;
        }
    }

    while(top != -1){
        postfix[x++] = operator[top--];
    }

    postfix[x] = '\0';
    return postfix;
}

int main(){
    char exp[100];
    scanf("%s", exp);
    printf("%s", convertinfixtopostfix(exp));
    return 0;
}
